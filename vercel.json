{
  "buildCommand": "npm run build && npm run generate-embeddings",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "nodeVersion": "18.x",
  "env": {
    "NODE_ENV": "production",
    "REDIS_URL": "@redis_url",
    "DATABASE_URL": "@database_url",
    "OPENAI_API_KEY": "@openai_api_key",
    "AGENT_API_KEY": "@agent_api_key"
  },
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  }
}
