# ── LLM providers (priorité : Claude > OpenAI > synthèse locale) ─────────────

# Claude API (Anthropic) — RECOMMANDÉ
# Modèle par défaut : claude-haiku-4-5-20251001 (général), claude-sonnet-4-6 (recherche)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI / API compatible (fallback si pas de clé Anthropic)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama (API compatible OpenAI, local)
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2

# Sans aucune clé : synthèse locale à partir de data/corpus/ uniquement.

# ── Sécurité ──────────────────────────────────────────────────────────────────

# Protège /api/evidence (Bearer token). Vide = route ouverte en dev.
AGENT_API_KEY=

# ── Base de données (optionnel) ───────────────────────────────────────────────

# PostgreSQL pour persistance des sessions et audit logs
# DATABASE_URL=postgresql://user:password@localhost:5432/african_agent
# DB_SSL=false

# ── Cache Redis (optionnel) ───────────────────────────────────────────────────

# REDIS_URL=redis://localhost:6379
