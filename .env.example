# ── LLM Souverain Local (PRIORITÉ 1) ─────────────────────────────────────────
# Ollama — LLM local, aucune clé API, fonctionne offline
# Installer : https://ollama.com | Modèle : ollama pull llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LLM Cloud (fallback optionnel) ───────────────────────────────────────────

# Claude API (Anthropic) — fallback si Ollama offline
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (fallback de dernier recours)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ordre de priorité : Ollama → Claude → OpenAI → synthèse locale (toujours disponible)

# ── Sécurité ──────────────────────────────────────────────────────────────────

# Protège /api/evidence (Bearer token). Vide = route ouverte en dev.
AGENT_API_KEY=

# ── Base de données (optionnel) ───────────────────────────────────────────────

# PostgreSQL pour persistance des sessions et audit logs
# DATABASE_URL=postgresql://user:password@localhost:5432/african_agent
# DB_SSL=false

# ── Cache Redis (optionnel) ───────────────────────────────────────────────────

# REDIS_URL=redis://localhost:6379
